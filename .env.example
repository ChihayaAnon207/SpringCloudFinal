# CloudBlog 环境变量配置
# 复制此文件为 .env 并修改其中的值
# cp .env.example .env

# ===== MySQL =====
# Docker Compose MySQL 密码
MYSQL_PASSWORD=Yx2474136983
# Spring Boot 服务连接 MySQL 的密码（默认与 MYSQL_PASSWORD 相同）
DB_PASSWORD=Yx2474136983

# ===== JWT =====
# JWT 签名密钥（gateway 和 user-service 需保持一致）
JWT_SECRET=CloudBlogSecretKey2024ForJWTTokenGeneration

# ===== MinIO =====
# Docker Compose MinIO 管理员账号密码
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Spring Boot 连接 MinIO 的密钥（默认与上面一致）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ===== 局域网部署（给小组成员用） =====
# 1. 在这台电脑上启动所有服务
# 2. 运行 ipconfig 找到你的局域网 IP（如 192.168.1.100）
# 3. 启动前设置环境变量：
#      set MINIO_ENDPOINT=http://192.168.1.100:9000
#   或者在启动文件服务的终端里直接指定：
#      MINIO_ENDPOINT=http://192.168.1.100:9000 mvn spring-boot:run -pl file-service
# 4. 其他成员在浏览器访问 http://192.168.1.100:3000 即可使用
#    （不需要安装任何东西，只需要浏览器）
