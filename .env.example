# CloudBlog 环境变量配置
# 复制此文件为 .env 并修改其中的值
# cp .env.example .env

# ===== MySQL =====
# Docker Compose MySQL 密码
MYSQL_PASSWORD=Yx2474136983
# Spring Boot 服务连接 MySQL 的密码（默认与 MYSQL_PASSWORD 相同）
DB_PASSWORD=Yx2474136983

# ===== JWT =====
# JWT 签名密钥（gateway 和 user-service 需保持一致）
JWT_SECRET=CloudBlogSecretKey2024ForJWTTokenGeneration

# ===== MinIO =====
# Docker Compose MinIO 管理员账号密码
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Spring Boot 连接 MinIO 的密钥（默认与上面一致）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
